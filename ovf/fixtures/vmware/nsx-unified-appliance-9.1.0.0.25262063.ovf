<?xml version="1.0" encoding="UTF-8"?>
<ovf:Envelope xmlns:ovf="http://schemas.dmtf.org/ovf/envelope/1" xmlns="http://schemas.dmtf.org/ovf/envelope/1" xmlns:rasd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData" xmlns:vssd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_VirtualSystemSettingData" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:vmw="http://www.vmware.com/schema/ovf">
  <References>
    <File ovf:href="nsx-unified-appliance.vmdk" ovf:size="8072292352" ovf:id="nsx-unified-appliance.vmdk_id"/>
  </References>
  <DeploymentOptionSection>
    <Info>The list of deployment options</Info>
    <Configuration ovf:id="small">
      <Label ovf:msgid="config.small.label">Small</Label>
      <Description ovf:msgid="config.small.description">
IMPORTANT: Small VM appliance size is suitable for lab and proof-of-concept deployment

This configuration requires the following:
* 4 vCPU
* 16GB RAM
* 300GB Storage
* VM hardware version 10 or greater (vSphere 5.5 or greater)</Description>
    </Configuration>
    <Configuration ovf:id="medium" ovf:default="true">
      <Label ovf:msgid="config.medium.label">Medium</Label>
      <Description ovf:msgid="config.medium.description">
IMPORTANT: This configuration is supported for Local Manager Production deployment ('NSX Manager' role)
           This is supported for Global Manager Production deployment

This configuration requires the following:
* 6 vCPU
* 24GB RAM
* 300GB Storage
* VM hardware version 10 or greater (vSphere 5.5 or greater)</Description>
    </Configuration>
    <Configuration ovf:id="large">
      <Label ovf:msgid="config.large.label">Large</Label>
      <Description ovf:msgid="config.large.description">
IMPORTANT: This configuration is supported for Local Manager Production deployment ('NSX Manager' role)
           This is supported for Global Manager Production deployment

This configuration requires the following:
* 12 vCPU
* 48GB RAM
* 300GB Storage
* VM hardware version 10 or greater (vSphere 5.5 or greater)</Description>
    </Configuration>
    <Configuration ovf:id="xlarge">
      <Label ovf:msgid="config.xlarge.label">ExtraLarge</Label>
      <Description ovf:msgid="config.xlarge.description">
IMPORTANT: This configuration is supported for Local Manager Production deployment ('NSX Manager' role)
           This is supported for Global Manager Production deployment

This configuration requires the following:
* 24 vCPU
* 96GB RAM
* 400GB Storage
* VM hardware version 10 or greater (vSphere 5.5 or greater)</Description>
    </Configuration>
  </DeploymentOptionSection>
  <NetworkSection>
    <Info>List of logical networks used in the package</Info>
    <Network ovf:name="Network 1">
      <Description>Network 1</Description>
    </Network>
  </NetworkSection>
  <vmw:IpAssignmentSection ovf:required="false" vmw:protocols="IPv4,IPv6" vmw:schemes="">
    <Info>Supported IP assignment schemes</Info>
  </vmw:IpAssignmentSection>
  <DiskSection>
    <Info>List of the virtual disks and partitions needed</Info>
    <Disk ovf:diskId="system" ovf:capacity="200" ovf:capacityAllocationUnits="byte * 2^30" ovf:format="http://www.vmware.com/interfaces/specifications/vmdk.html#streamOptimized" ovf:fileRef="nsx-unified-appliance.vmdk_id" ovf:populatedSize="4312137728"/>
    <ovf:Disk ovf:diskId="secondary" ovf:capacity="102400" ovf:capacityAllocationUnits="byte * 2^20" ovf:format="http://www.vmware.com/interfaces/specifications/vmdk.html#streamOptimized"/>
    <ovf:Disk ovf:diskId="disk100GB" ovf:capacity="102400" ovf:capacityAllocationUnits="byte * 2^20" ovf:format="http://www.vmware.com/interfaces/specifications/vmdk.html#streamOptimized"/>
  </DiskSection>
  <VirtualSystem ovf:id="nsx-unified-appliance">
    <Info>A virtual machine</Info>
    <ProductSection ovf:required="false">
      <Info>VM ISV branding information</Info>
      <Product>nsx-unified-appliance</Product>
      <Vendor>VMware, Inc</Vendor>
      <!--
            Version is the actual product version in the
            form X.X.X.X where X is an unsigned 16-bit integer.

            FullVersion is a descriptive version string
            including, for example, alpha or beta designations
            and other release criteria.
        -->
      <Version>9.1.0.0</Version>
      <FullVersion>9.1.0.0.25262063</FullVersion>
      <ProductUrl/>
      <VendorUrl/>
      <AppUrl>http://${vami.ip0.nsx-unified-appliance}/</AppUrl>
      <Category>Application</Category>
      <!-- BEGIN OVF PROPERTIES -->
      <Property ovf:key="nsx_grub_passwd" ovf:type="string" ovf:userConfigurable="true" ovf:password="true">
        <Label ovf:msgid="grub.password.label">System GRUB Root User Password</Label>
        <Description ovf:msgid="grub.password.desc">The password for GRUB root user for this VM. </Description>
      </Property>
      <Property ovf:key="nsx_grub_menu_timeout" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="grub.menu.timeout.label">System GRUB menu timeout</Label>
        <Description ovf:msgid="grub.menu.timeout.desc">The timeout to display GRUB menu for this VM. </Description>
      </Property>
      <Property ovf:key="nsx_passwd_0" ovf:type="string" ovf:userConfigurable="true" ovf:qualifiers="MinLen(8)" ovf:password="true">
        <Label ovf:msgid="root.user.password.label">System Root User Password</Label>
        <Description ovf:msgid="root.user.password.desc">The password for root user for this VM.
Please follow the password complexity rule as below:
    - minimum of 8 characters in length
    - &gt;=1 uppercase character
    - &gt;=1 lowercase character
    - &gt;=1 numeric character
    - &gt;=1 special character
    - &gt;=5 unique characters
    - default password complexity rules as enforced by the Linux PAM module
    NOTE: Password strength validation will occur during VM boot.  If the password does not meet the above criteria then login as root user for the change password prompt to appear. </Description>
      </Property>
      <Property ovf:key="nsx_cli_passwd_0" ovf:type="string" ovf:userConfigurable="true" ovf:qualifiers="MinLen(8)" ovf:password="true">
        <Label ovf:msgid="cli.user.password.label">CLI "admin" User Password</Label>
        <Description ovf:msgid="cli.user.password.desc">The password for default CLI user for this VM.
Please follow the password complexity rule as below:
    - minimum of 8 characters in length
    - &gt;=1 uppercase character
    - &gt;=1 lowercase character
    - &gt;=1 numeric character
    - &gt;=1 special character
    - &gt;=5 unique characters
    - default password complexity rules as enforced by the Linux PAM module
    NOTE: Password strength validation will occur during VM boot.  If the password does not meet the above criteria then login as admin user for the change password prompt to appear. </Description>
      </Property>
      <Property ovf:key="nsx_cli_audit_passwd_0" ovf:type="string" ovf:userConfigurable="true" ovf:password="true">
        <Label ovf:msgid="cli.audit.user.password.label">CLI "audit" User Password</Label>
        <Description ovf:msgid="cli.audit.user.password.desc">The password for audit CLI user for this VM.
Please follow the password complexity rule as below:
    - minimum of 8 characters in length
    - &gt;=1 uppercase character
    - &gt;=1 lowercase character
    - &gt;=1 numeric character
    - &gt;=1 special character
    - &gt;=5 unique characters
    - default password complexity rules as enforced by the Linux PAM module
    NOTE: Password strength validation will occur during VM boot.  If the password does not meet the above criteria then login as admin user and use the NSX CLI command "set user audit" to change the audit user password. </Description>
      </Property>
      <Property ovf:key="nsx_cli_username" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="cli.user.adminusername.label">CLI "admin" username (default: admin)</Label>
        <Description ovf:msgid="cli.user.adminusername.desc">Username of administrator user.</Description>
      </Property>
      <Property ovf:key="nsx_cli_audit_username" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="cli.user.auditusername.label">CLI "audit" username (default: audit)</Label>
        <Description ovf:msgid="cli.user.auditusername.desc">Username of auditor user.</Description>
      </Property>
      <Property ovf:key="extraPara" ovf:type="string" ovf:userConfigurable="true" ovf:password="true">
        <Label ovf:msgid="extraPara.label">Optional parameters</Label>
        <Description ovf:msgid="extraPara.desc">For internal use only.</Description>
      </Property>
      <Category ovf:msgid="network.ipv4.category">Network properties</Category>
      <Property ovf:key="nsx_hostname" ovf:type="string" ovf:userConfigurable="true" ovf:qualifiers="MinLen(1),MaxLen(253)">
        <Label ovf:msgid="hostname.label">Hostname</Label>
        <Description ovf:msgid="hostname.desc">The hostname for this VM.
    Valid characters for hostname are A-Z, a-z, 0-9, dot (.) and hyphen (-). A hostname may not start with a hyphen. Each element of the hostname must be from 1 to 63 characters long and the entire hostname, including the dots, can be at most 253 characters long.
    NOTE: If hostname contains invalid characters, then the appliance gets deployed with 'nsx-manager' as hostname. </Description>
      </Property>
      <Property
        ovf:key="nsx_role"
        ovf:type="string"
        ovf:userConfigurable="true"
        ovf:value="NSX Manager"
        ovf:qualifiers="ValueMap{&quot;NSX Manager&quot;,&quot;NSX Global Manager&quot;}">
        <Label ovf:msgid="nsx_role.label">Rolename</Label>
        <Description ovf:msgid="nsx_role.desc">The role for this VM. Currently supports 'NSX Global Manager' OR 'NSX Manager' as rolename. </Description>
      </Property>
      <Property ovf:key="nsx_ip_0" ovf:type="string" ovf:userConfigurable="true" ovf:qualifiers="MinLen(1)">
        <Label ovf:msgid="network.ipv4.address.label">Management Network IPv4 Address</Label>
        <Description ovf:msgid="network.ipv4.address.desc">The IPv4 Address for the first interface. For IPv6-only deployments use the value: None</Description>
      </Property>
      <Property ovf:key="nsx_netmask_0" ovf:type="string" ovf:userConfigurable="true" ovf:qualifiers="MinLen(1)">
        <Label ovf:msgid="network.ipv4.netmask.label">Management Network Netmask</Label>
        <Description ovf:msgid="network.ipv4.netmask.desc">The netmask for the first interface. For IPv6-only deployments use the value: None</Description>
      </Property>
      <Property ovf:key="nsx_gateway_0" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="network.ipv4.gateway.label">Default IPv4 Gateway</Label>
        <Description ovf:msgid="network.ipv4.gateway.desc">The default IPv4 gateway for this VM.</Description>
      </Property>
      <Property ovf:key="nsx_ip6_0" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="network.ipv6.address.label">Management Network IPv6 Address</Label>
        <Description ovf:msgid="network.ipv6.address.desc">The IPv6 Address for the first interface.</Description>
      </Property>
      <Property ovf:key="nsx_netmask6_0" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="network.ipv6.netmask.label">Management IPv6 Network Netmask Prefix</Label>
        <Description ovf:msgid="network.ipv6.netmask.desc">The IPv6 netmask prefix for the first interface. (ex.- 64)</Description>
      </Property>
      <Property ovf:key="nsx_gateway6_0" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="network.ipv6.gateway.label">Default IPv6 Gateway</Label>
        <Description ovf:msgid="network.ipv6.gateway.desc">The default IPv6 gateway for this VM.</Description>
      </Property>
      <Category ovf:msgid="dns.category">DNS</Category>
      <Property ovf:key="nsx_dns1_0" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="dns.primary.label">DNS Server list</Label>
        <Description ovf:msgid="dns.primary.desc">The space separated DNS server list for this VM (valid only if an IPv4 address is specified for the first interface).
    NOTE: At most three name servers can be configured (first 3 name servers passed in list will be used and all other will be ignored)</Description>
      </Property>
      <Property ovf:key="nsx_domain_0" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="dns.domain.label">Domain Search List</Label>
        <Description ovf:msgid="dns.domain.desc">The space separated domain search list for this VM (valid only if an IPv4 address is specified for the first interface).</Description>
      </Property>
      <Category ovf:msgid="services.configuration.category">Services Configuration</Category>
      <Property ovf:key="nsx_ntp_0" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="ntp.label">NTP Server List</Label>
        <Description ovf:msgid="ntp.desc">The NTP server list(space separated) for this VM.</Description>
      </Property>
      <Property ovf:key="nsx_isSSHEnabled" ovf:value="false" ovf:type="boolean" ovf:userConfigurable="true">
        <Label ovf:msgid="ssh.enable.label">Enable SSH</Label>
        <Description ovf:msgid="ssh.enable.desc">Enabling SSH service is not recommended for security reasons.</Description>
      </Property>
      <Property ovf:key="nsx_allowSSHRootLogin" ovf:value="false" ovf:type="boolean" ovf:userConfigurable="true">
        <Label ovf:msgid="ssh.allowrootlogin.label">Allow root SSH logins</Label>
        <Description ovf:msgid="ssh.allowrootlogin.desc">Allowing root SSH logins is not recommended for security reasons.</Description>
      </Property>
      <Property ovf:key="nsx_swIntegrityCheck" ovf:value="false" ovf:type="boolean" ovf:userConfigurable="true">
        <Label ovf:msgid="ssh.softwareintchecker.label">Software Integrity Checker</Label>
        <Description ovf:msgid="ssh.softwareintchecker.desc">Software Integrity Checker is required only for NDcPP 2.2</Description>
      </Property>
      <Category ovf:msgid="internal.properties.category">Internal Properties - Do not set these parameters.</Category>
      <Property ovf:key="mpIp" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="mpIp.label">Manager IP</Label>
        <Description ovf:msgid="mpIp.desc">For internal use only. Do not set this parameter. </Description>
      </Property>
      <Property ovf:key="mpToken" ovf:type="string" ovf:userConfigurable="true" ovf:password="true">
        <Label ovf:msgid="mpToken.label">Manager Token</Label>
        <Description ovf:msgid="mpToken.desc">For internal use only. Do not set this parameter. </Description>
      </Property>
      <Property ovf:key="mpThumbprint" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="mpThumbprint.label">Manager Thumbprint</Label>
        <Description ovf:msgid="mpThumbprint.desc">For internal use only. Do not set this parameter. </Description>
      </Property>
      <Property ovf:key="mpNodeId" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="mpNodeId.label">Manager Node ID</Label>
        <Description ovf:msgid="mpNodeId.desc">For internal use only. Do not set this parameter. </Description>
      </Property>
      <Property ovf:key="mpClusterId" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="mpClusterId.label">Cluster ID of First Manager Cluster</Label>
        <Description ovf:msgid="mpClusterId.desc">For internal use only. Do not set this parameter. </Description>
      </Property>
      <!-- END OVF PROPERTIES -->
    </ProductSection>
