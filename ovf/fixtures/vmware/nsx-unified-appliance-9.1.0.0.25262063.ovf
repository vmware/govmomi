        <rasd:HostResource>ovf:/disk/disk100GB</rasd:HostResource>
        <rasd:InstanceID xmlns:rasd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData">7</rasd:InstanceID>
        <rasd:Parent>4</rasd:Parent>
        <rasd:ResourceType>17</rasd:ResourceType>
      </Item>
      <vmw:Config ovf:required="false" vmw:key="tools.syncTimeWithHost" vmw:value="false"/>
      <vmw:ExtraConfig vmw:key="time.synchronize.continue" vmw:value="false"/>
      <vmw:ExtraConfig vmw:key="time.synchronize.restore" vmw:value="false"/>
      <vmw:ExtraConfig vmw:key="time.synchronize.resume.disk" vmw:value="false"/>
      <vmw:ExtraConfig vmw:key="time.synchronize.shrink" vmw:value="false"/>
      <vmw:ExtraConfig vmw:key="time.synchronize.tools.startup" vmw:value="false"/>
      <vmw:ExtraConfig vmw:key="ethernet0.rxDataRingEnabled" vmw:value="0"/>
      <vmw:ExtraConfig vmw:key="ethernet1.rxDataRingEnabled" vmw:value="0"/>
      <vmw:ExtraConfig vmw:key="ethernet2.rxDataRingEnabled" vmw:value="0"/>
      <vmw:ExtraConfig vmw:key="ethernet3.rxDataRingEnabled" vmw:value="0"/>
      <vmw:ExtraConfig vmw:key="isolation.tools.diskWiper.disable" vmw:value="true"/>
      <vmw:ExtraConfig vmw:key="isolation.tools.memSchedFakeSampleStats.disable" vmw:value="true"/>
      <vmw:ExtraConfig vmw:key="isolation.tools.diskShrink.disable" vmw:value="true"/>
      <vmw:ExtraConfig vmw:key="isolation.tools.vmxDnDVersionGet.disable" vmw:value="true"/>
      <vmw:ExtraConfig vmw:key="isolation.tools.unityActive.disable" vmw:value="true"/>
      <vmw:ExtraConfig vmw:key="isolation.tools.guestDnDVersionSet.disable" vmw:value="true"/>
      <vmw:ExtraConfig vmw:key="snapshot.maxSnapshots" vmw:value="0"/>
      <vmw:ExtraConfig vmw:key="stealclock.enable" vmw:value="true"/>
            <vmw:ExtraConfig vmw:key="RemoteDisplay.maxConnections" vmw:value="1"/>
    </VirtualHardwareSection>
  </VirtualSystem>
  <!-- BEGIN L10N Strings -->
<Strings xml:lang="ja-JP">
    <Msg ovf:msgid="config.small.label">Small</Msg>
    <Msg ovf:msgid="config.small.description">
重要: Small サイズの仮想マシン アプライアンスは、ラボ環境や概念実証環境に適しています。

この構成では次のものが必要です。
* 4 個の vCPU
* 16 GB の RAM
* 300 GB のストレージ
* 仮想マシン ハードウェア バージョン 10 以降 (vSphere 5.5 以降)</Msg>
    <Msg ovf:msgid="config.medium.label">Medium</Msg>
    <Msg ovf:msgid="config.medium.description">
重要: この構成は、ローカル マネージャの本番環境での展開 (NSX Manager ロール) でサポートされます。
           これは、グローバル マネージャの本番環境での展開でサポートされます。

この構成では次のものが必要です。
* 6 個の vCPU
* 24 GB の RAM
* 300 GB のストレージ
* 仮想マシン ハードウェア バージョン 10 以降 (vSphere 5.5 以降)</Msg>
    <Msg ovf:msgid="config.large.label">Large</Msg>
    <Msg ovf:msgid="config.large.description">
重要: この構成は、ローカル マネージャの本番環境での展開 (NSX Manager ロール) でサポートされます。
           これは、グローバル マネージャの本番環境での展開でサポートされます。

この構成では次のものが必要です。
* 12 個の vCPU
* 48 GB の RAM
* 300 GB のストレージ
* 仮想マシン ハードウェア バージョン 10 以降 (vSphere 5.5 以降)</Msg>
    <Msg ovf:msgid="config.xlarge.label">ExtraLarge</Msg>
    <Msg ovf:msgid="config.xlarge.description">
重要: この構成は、ローカル マネージャの本番環境での展開 (NSX Manager ロール) でサポートされます。
           これは、グローバル マネージャの本番環境での展開でサポートされます。

この構成では次のものが必要です。
* 24 個の vCPU
* 96 GB の RAM
* 400 GB のストレージ
* 仮想マシン ハードウェア バージョン 10 以降 (vSphere 5.5 以降)</Msg>
    <Msg ovf:msgid="grub.password.label">システム GRUB root ユーザーのパスワード</Msg>
    <Msg ovf:msgid="grub.password.desc">この仮想マシンの GRUB root ユーザーのパスワード。</Msg>
    <Msg ovf:msgid="grub.menu.timeout.label">システム GRUB メニューのタイムアウト</Msg>
    <Msg ovf:msgid="grub.menu.timeout.desc">この仮想マシンの GRUB メニューを表示するタイムアウト。</Msg>
    <Msg ovf:msgid="root.user.password.label">システムの root ユーザーのパスワード</Msg>
    <Msg ovf:msgid="root.user.password.desc">この仮想マシンの root ユーザーのパスワード。
次のパスワード強度ルールに従ってください。
    - 8 文字以上の長さ
    - 1 つ以上の大文字
    - 1 つ以上の小文字
    - 1 つ以上の数字
    - 1 つ以上の特殊文字
    - 5 個以上の異なる文字
    - Linux PAM モジュールによって適用されるデフォルトのパスワード強度ルール
    注: パスワードの強度は、仮想マシンの起動時に検証されます。パスワードが上記の基準を満たしていない場合、root ユーザーとしてログインすると、パスワードの変更を求めるプロンプトが表示されます。 </Msg>
    <Msg ovf:msgid="cli.user.password.label">CLI admin ユーザー パスワード</Msg>
    <Msg ovf:msgid="cli.user.password.desc">この仮想マシンのデフォルトの CLI ユーザーのパスワード。
次のパスワード強度ルールに従ってください。
    - 8 文字以上の長さ
    - 1 つ以上の大文字
    - 1 つ以上の小文字
    - 1 つ以上の数字
    - 1 つ以上の特殊文字
    - 5 個以上の異なる文字
    - Linux PAM モジュールによって適用されるデフォルトのパスワード強度ルール
    注: パスワードの強度は、仮想マシンの起動時に検証されます。パスワードが上記の基準を満たしていない場合、admin ユーザーとしてログインすると、パスワードの変更を求めるプロンプトが表示されます。 </Msg>
    <Msg ovf:msgid="cli.audit.user.password.label">CLI audit ユーザー パスワード</Msg>
    <Msg ovf:msgid="cli.audit.user.password.desc">この仮想マシンの audit CLI ユーザーのパスワード。
次のパスワード強度ルールに従ってください。
    - 8 文字以上の長さ
    - 1 つ以上の大文字
    - 1 つ以上の小文字
    - 1 つ以上の数字
    - 1 つ以上の特殊文字
    - 5 個以上の異なる文字
    - Linux PAM モジュールによって適用されるデフォルトのパスワード強度ルール
    注: パスワードの強度は、仮想マシンの起動時に検証されます。パスワードが上記の基準を満たしていない場合は、admin ユーザーとしてログインし、NSX CLI コマンド set user audit を使用して audit ユーザーのパスワードを変更します。 </Msg>
    <Msg ovf:msgid="cli.user.adminusername.label">CLI の「admin」ユーザー名 (デフォルト: admin)</Msg>
    <Msg ovf:msgid="cli.user.adminusername.desc">管理者ユーザーのユーザー名。</Msg>
    <Msg ovf:msgid="cli.user.auditusername.label">CLI の「audit」ユーザー名 (デフォルト: audit)</Msg>
    <Msg ovf:msgid="cli.user.auditusername.desc">監査者ユーザーのユーザー名。</Msg>
    <Msg ovf:msgid="extraPara.label">オプション パラメータ</Msg>
    <Msg ovf:msgid="extraPara.desc">内部使用のみ。</Msg>
    <Msg ovf:msgid="network.ipv4.category">ネットワーク プロパティ</Msg>
    <Msg ovf:msgid="hostname.label">ホスト名</Msg>
    <Msg ovf:msgid="hostname.desc">この仮想マシンのホスト名。
    ホスト名に有効な文字は、A ～ Z、a ～ z、0 ～ 9、ドット (.)、ハイフン (-) です。ホスト名はハイフンで始めることはできません。ホスト名の各要素の長さは 1 ～ 63 文字にし、ホスト名全体 (ドットを含む) は 253 文字以下にする必要があります。
    注: ホスト名に無効な文字が含まれている場合、アプライアンスは nsx-manager というホスト名で展開されます。</Msg>
    <Msg ovf:msgid="nsx_role.label">ロール名</Msg>
    <Msg ovf:msgid="nsx_role.desc">この仮想マシンのロール。現在、ロール名として NSX Global Manager または NSX Manager がサポートされています。</Msg>
    <Msg ovf:msgid="network.ipv4.address.label">管理ネットワーク IPv4 アドレス</Msg>
    <Msg ovf:msgid="network.ipv4.address.desc">最初のインターフェイスの IPv4 アドレス。IPv6 のみの展開の場合は、[なし] を使用します</Msg>
    <Msg ovf:msgid="network.ipv4.netmask.label">管理ネットワークのネットマスク</Msg>
    <Msg ovf:msgid="network.ipv4.netmask.desc">最初のインターフェイスのネットマスク。IPv6 のみの展開の場合は、[なし] を使用します</Msg>
    <Msg ovf:msgid="network.ipv4.gateway.label">デフォルト IPv4 ゲートウェイ</Msg>
    <Msg ovf:msgid="network.ipv4.gateway.desc">この仮想マシンのデフォルト IPv4 ゲートウェイ。</Msg>
    <Msg ovf:msgid="network.ipv6.address.label">管理ネットワーク IPv6 アドレス</Msg>
    <Msg ovf:msgid="network.ipv6.address.desc">最初のインターフェイスの IPv6 アドレス。</Msg>
    <Msg ovf:msgid="network.ipv6.netmask.label">管理 IPv6 ネットワーク ネットマスク プレフィックス</Msg>
    <Msg ovf:msgid="network.ipv6.netmask.desc">最初のインターフェイスの IPv6 ネットマスク プレフィックス。(例: - 64)</Msg>
    <Msg ovf:msgid="network.ipv6.gateway.label">デフォルト IPv6 ゲートウェイ</Msg>
    <Msg ovf:msgid="network.ipv6.gateway.desc">この仮想マシンのデフォルト IPv6 ゲートウェイ。</Msg>
    <Msg ovf:msgid="dns.category">DNS</Msg>
    <Msg ovf:msgid="dns.primary.label">DNS サーバ リスト</Msg>
    <Msg ovf:msgid="dns.primary.desc">この仮想マシンのスペース区切りの DNS サーバ リスト (最初のインターフェイスに IPv4 アドレスが指定されている場合にのみ有効)。
    注: ネーム サーバは 3 つまで構成できます (リストの最初の 3 つのネーム サーバが使用され、それ以外はすべて無視されます)</Msg>
    <Msg ovf:msgid="dns.domain.label">ドメイン検索リスト</Msg>
    <Msg ovf:msgid="dns.domain.desc">この仮想マシンのスペース区切りのドメイン検索リスト (最初のインターフェイスに IPv4 アドレスが指定されている場合にのみ有効)。</Msg>
    <Msg ovf:msgid="services.configuration.category">サービス構成</Msg>
    <Msg ovf:msgid="ntp.label">NTP サーバ リスト</Msg>
    <Msg ovf:msgid="ntp.desc">この仮想マシンの NTP サーバ リスト (スペース区切り)。</Msg>
    <Msg ovf:msgid="ssh.enable.label">SSH の有効化</Msg>
    <Msg ovf:msgid="ssh.enable.desc">セキュリティ上の理由で SSH サービスの有効化は推奨されません。</Msg>
    <Msg ovf:msgid="ssh.allowrootlogin.label">root SSH ログインを許可</Msg>
    <Msg ovf:msgid="ssh.allowrootlogin.desc">セキュリティ上の理由で root SSH ログインの許可は推奨されません。</Msg>
    <Msg ovf:msgid="ssh.softwareintchecker.label">ソフトウェア整合性チェッカー</Msg>
    <Msg ovf:msgid="ssh.softwareintchecker.desc">ソフトウェア整合性チェッカーは NDcPP 2.2 でのみ必要です</Msg>
    <Msg ovf:msgid="internal.properties.category">内部プロパティ - これらのパラメータは設定しないでください。</Msg>
    <Msg ovf:msgid="mpIp.label">Manager の IP</Msg>
    <Msg ovf:msgid="mpIp.desc">内部使用のみ。このパラメータは設定しない。</Msg>
    <Msg ovf:msgid="mpToken.label">Manager トークン</Msg>
    <Msg ovf:msgid="mpToken.desc">内部使用のみ。このパラメータは設定しない。</Msg>
    <Msg ovf:msgid="mpThumbprint.label">Manager のサムプリント</Msg>
    <Msg ovf:msgid="mpThumbprint.desc">内部使用のみ。このパラメータは設定しない。</Msg>
    <Msg ovf:msgid="mpNodeId.label">マネージャ ノード ID</Msg>
    <Msg ovf:msgid="mpNodeId.desc">内部使用のみ。このパラメータは設定しない。</Msg>
    <Msg ovf:msgid="mpClusterId.label">最初のマネージャ クラスタのクラスタ ID</Msg>
    <Msg ovf:msgid="mpClusterId.desc">内部使用のみ。このパラメータは設定しない。</Msg>
</Strings>
<Strings xml:lang="fr-FR">
    <Msg ovf:msgid="config.small.label">Petite</Msg>
    <Msg ovf:msgid="config.small.description">
IMPORTANT : un dispositif de machines virtuelles de petite taille convient au déploiement de concept en laboratoire et technique

Cette configuration requiert les éléments suivants :
* 4 vCPU
* 16 Go de RAM
* Stockage de 300 Go
* Matériel de VM version 10 ou supérieure (vSphere 5.5 ou version supérieure)</Msg>
    <Msg ovf:msgid="config.medium.label">Moyenne</Msg>
    <Msg ovf:msgid="config.medium.description">
IMPORTANT : cette configuration est prise en charge pour le déploiement de Local Manager Production (rôle NSX Manager)
           Ceci est pris en charge pour le déploiement de Global Manager Production

Cette configuration requiert les éléments suivants :
* 6 vCPU
* 24 Go de RAM
* Stockage de 300 Go
* Matériel de VM version 10 ou supérieure (vSphere 5.5 ou version supérieure)</Msg>
    <Msg ovf:msgid="config.large.label">Volumineuse</Msg>
    <Msg ovf:msgid="config.large.description">
IMPORTANT : cette configuration est prise en charge pour le déploiement de Local Manager Production (rôle NSX Manager)
           Ceci est pris en charge pour le déploiement de Global Manager Production

Cette configuration requiert les éléments suivants :
* 12 vCPU
* 48 Go de RAM
* Stockage de 300 Go
* Matériel de VM version 10 ou supérieure (vSphere 5.5 ou version supérieure)</Msg>
    <Msg ovf:msgid="config.xlarge.label">Très grand</Msg>
    <Msg ovf:msgid="config.xlarge.description">
IMPORTANT : cette configuration est prise en charge pour le déploiement de Local Manager Production (rôle NSX Manager)
           Ceci est pris en charge pour le déploiement de Global Manager Production

Cette configuration requiert les éléments suivants :
* 24 vCPU
* 96 Go de RAM
* Stockage de 400 Go
* Matériel de VM version 10 ou supérieure (vSphere 5.5 ou version supérieure)</Msg>
    <Msg ovf:msgid="grub.password.label">Mot de passe de l'utilisateur racine du système GRUB</Msg>
    <Msg ovf:msgid="grub.password.desc">Mot de passe de l'utilisateur racine GRUB de cette VM. </Msg>
    <Msg ovf:msgid="grub.menu.timeout.label">Délai d'expiration du menu système GRUB</Msg>
    <Msg ovf:msgid="grub.menu.timeout.desc">Délai d'expiration de l'affichage du menu GRUB pour cette VM. </Msg>
    <Msg ovf:msgid="root.user.password.label">Mot de passe de l'utilisateur racine du système</Msg>
    <Msg ovf:msgid="root.user.password.desc">Mot de passe de l'utilisateur racine de cette VM.
Veuillez suivre la règle de complexité du mot de passe ci-dessous :
    - une longueur minimale de 8 caractères
    - &gt;=1 caractère majuscule
    - &gt;=1 caractère minuscule
    - &gt;=1 caractère numérique
    - &gt;=1 caractère spécial
    - &gt;=5 caractères uniques
    - règles de complexité de mot de passe par défaut appliquées par le module PAM Linux
    REMARQUE : la validation de la force du mot de passe se produira lors du démarrage de la VM. Si le mot de passe ne répond pas aux critères ci-dessus, connectez-vous en tant qu'utilisateur racine pour que l'invite de modification du mot de passe s'affiche. </Msg>
    <Msg ovf:msgid="cli.user.password.label">Mot de passe de l'utilisateur « Admin » de la CLI</Msg>
    <Msg ovf:msgid="cli.user.password.desc">Mot de passe de l'utilisateur de CLI par défaut pour cette VM.
Veuillez suivre la règle de complexité du mot de passe ci-dessous :
    - une longueur minimale de 8 caractères
    - &gt;=1 caractère majuscule
    - &gt;=1 caractère minuscule
    - &gt;=1 caractère numérique
    - &gt;=1 caractère spécial
    - &gt;=5 caractères uniques
    - règles de complexité de mot de passe par défaut appliquées par le module PAM Linux
    REMARQUE : la validation de la force du mot de passe se produira lors du démarrage de la VM. Si le mot de passe ne répond pas aux critères ci-dessus, connectez-vous en tant qu'utilisateur Admin pour que l'invite de modification du mot de passe s'affiche. </Msg>
    <Msg ovf:msgid="cli.audit.user.password.label">Mot de passe de l'utilisateur « audit » de la CLI</Msg>
    <Msg ovf:msgid="cli.audit.user.password.desc">Mot de passe de l'utilisateur d'audit de la CLI par défaut pour cette VM.
Veuillez suivre la règle de complexité du mot de passe ci-dessous :
    - une longueur minimale de 8 caractères
    - &gt;=1 caractère majuscule
    - &gt;=1 caractère minuscule
    - &gt;=1 caractère numérique
    - &gt;=1 caractère spécial
    - &gt;=5 caractères uniques
    - règles de complexité de mot de passe par défaut appliquées par le module PAM Linux
    REMARQUE : la validation de la force du mot de passe se produira lors du démarrage de la VM. Si le mot de passe ne répond pas aux critères ci-dessus, connectez-vous en tant qu'utilisateur Admin et utilisez la commande CLI NSX « set user audit » pour modifier le mot de passe de l'utilisateur d'audit. </Msg>
    <Msg ovf:msgid="cli.user.adminusername.label">Nom d'utilisateur « admin » de la CLI (par défaut : admin)</Msg>
    <Msg ovf:msgid="cli.user.adminusername.desc">Nom d'utilisateur de l'utilisateur administrateur.</Msg>
    <Msg ovf:msgid="cli.user.auditusername.label">Nom d'utilisateur « audit » de la CLI (par défaut : audit)</Msg>
    <Msg ovf:msgid="cli.user.auditusername.desc">Nom d'utilisateur de l'auditeur.</Msg>
    <Msg ovf:msgid="extraPara.label">Paramètres facultatifs</Msg>
    <Msg ovf:msgid="extraPara.desc">Pour une utilisation interne uniquement.</Msg>
    <Msg ovf:msgid="network.ipv4.category">Propriétés réseau</Msg>
    <Msg ovf:msgid="hostname.label">Nom d'hôte</Msg>
    <Msg ovf:msgid="hostname.desc">Nom d'hôte de cette VM.
    Les caractères valides pour le nom d'hôte sont A-Z, a-z, 0-9, point (.) et trait d'union (-). Un nom d'hôte ne peut pas commencer par un trait d'union. Chaque élément du nom d'hôte doit comporter entre 1 et 63 caractères et l'intégralité du nom d'hôte, y compris les points, peut comporter au maximum 253 caractères.
    REMARQUE : si le nom d'hôte contient des caractères non valides, le dispositif est alors déployé avec « nsx-manager » comme nom d'hôte.</Msg>
    <Msg ovf:msgid="nsx_role.label">Nom du rôle</Msg>
    <Msg ovf:msgid="nsx_role.desc">Le rôle de cette VM. Prend actuellement en charge « 'NSX Global Manager » OU « NSX Manager » comme nom de rôle.</Msg>
    <Msg ovf:msgid="network.ipv4.address.label">Adresse IPv4 du réseau de gestion</Msg>
    <Msg ovf:msgid="network.ipv4.address.desc">Adresse IPv4 de la première interface. Pour les déploiements IPv6 uniquement, utilisez la valeur : aucune</Msg>
    <Msg ovf:msgid="network.ipv4.netmask.label">Masque du réseau de gestion</Msg>
    <Msg ovf:msgid="network.ipv4.netmask.desc">Masque de réseau de la première interface. Pour les déploiements IPv6 uniquement, utilisez la valeur : aucune</Msg>
    <Msg ovf:msgid="network.ipv4.gateway.label">Passerelle IPv4 par défaut</Msg>
    <Msg ovf:msgid="network.ipv4.gateway.desc">Passerelle IPv4 par défaut de cette VM.</Msg>
    <Msg ovf:msgid="network.ipv6.address.label">Adresse IPv6 du réseau de gestion</Msg>
    <Msg ovf:msgid="network.ipv6.address.desc">Adresse IPv6 de la première interface.</Msg>
    <Msg ovf:msgid="network.ipv6.netmask.label">Préfixe du masque de réseau du réseau IPv6 de gestion</Msg>
    <Msg ovf:msgid="network.ipv6.netmask.desc">Préfixe du masque de réseau IPv6 de la première interface. (par exemple,- 64)</Msg>
    <Msg ovf:msgid="network.ipv6.gateway.label">Passerelle IPv6 par défaut</Msg>
    <Msg ovf:msgid="network.ipv6.gateway.desc">Passerelle IPv6 par défaut de cette VM.</Msg>
    <Msg ovf:msgid="dns.category">DNS</Msg>
    <Msg ovf:msgid="dns.primary.label">Liste des serveurs DNS</Msg>
    <Msg ovf:msgid="dns.primary.desc">Liste de serveurs DNS séparés par des espaces pour cette VM (valide uniquement si une adresse IPv4 est spécifiée pour la première interface).
    REMARQUE : trois serveurs de noms au maximum peuvent être configurés (les 3 premiers serveurs de noms transmis dans la liste seront utilisés et tous les autres seront ignorés)</Msg>
    <Msg ovf:msgid="dns.domain.label">Liste de recherche de domaines</Msg>
    <Msg ovf:msgid="dns.domain.desc">Liste de recherche de domaines séparés par des espaces pour cette VM (valide uniquement si une adresse IPv4 est spécifiée pour la première interface).</Msg>
    <Msg ovf:msgid="services.configuration.category">Configuration des services</Msg>
    <Msg ovf:msgid="ntp.label">Liste des serveurs NTP</Msg>
    <Msg ovf:msgid="ntp.desc">Liste des serveurs NTP (séparés par des espaces) pour cette VM.</Msg>
    <Msg ovf:msgid="ssh.enable.label">Activer SSH</Msg>
    <Msg ovf:msgid="ssh.enable.desc">L'activation du service SSH n'est pas recommandée pour des raisons de sécurité.</Msg>
    <Msg ovf:msgid="ssh.allowrootlogin.label">Autoriser les connexions SSH racines</Msg>
    <Msg ovf:msgid="ssh.allowrootlogin.desc">L'activation des connexions SSH racines n'est pas recommandée pour des raisons de sécurité.</Msg>
    <Msg ovf:msgid="ssh.softwareintchecker.label">Outil de vérification de l'intégrité du logiciel</Msg>
    <Msg ovf:msgid="ssh.softwareintchecker.desc">L'outil de vérification de l'intégrité du logiciel n'est requis que pour NDcPP 2.2</Msg>
    <Msg ovf:msgid="internal.properties.category">Propriétés internes : ne définissez pas ces paramètres.</Msg>
    <Msg ovf:msgid="mpIp.label">Adresse IP du gestionnaire</Msg>
    <Msg ovf:msgid="mpIp.desc">Pour une utilisation interne uniquement. Ne définissez pas ce paramètre.</Msg>
    <Msg ovf:msgid="mpToken.label">Jeton du gestionnaire</Msg>
    <Msg ovf:msgid="mpToken.desc">Pour une utilisation interne uniquement. Ne définissez pas ce paramètre.</Msg>
    <Msg ovf:msgid="mpThumbprint.label">Empreinte numérique du gestionnaire</Msg>
    <Msg ovf:msgid="mpThumbprint.desc">Pour une utilisation interne uniquement. Ne définissez pas ce paramètre.</Msg>
    <Msg ovf:msgid="mpNodeId.label">ID du nœud de gestionnaire</Msg>
    <Msg ovf:msgid="mpNodeId.desc">Pour une utilisation interne uniquement. Ne définissez pas ce paramètre.</Msg>
    <Msg ovf:msgid="mpClusterId.label">ID du cluster du premier cluster de gestionnaire</Msg>
    <Msg ovf:msgid="mpClusterId.desc">Pour une utilisation interne uniquement. Ne définissez pas ce paramètre.</Msg>
</Strings>
<Strings xml:lang="es-ES">
    <Msg ovf:msgid="config.small.label">Pequeño</Msg>
    <Msg ovf:msgid="config.small.description">
IMPORTANTE: El tamaño de dispositivo de máquina virtual pequeño es adecuado para implementaciones de prueba de concepto y laboratorio

Esta configuración requiere lo siguiente:
* 4 vCPU
* 16GB de RAM
* 300GB de almacenamiento
* Versión 10 o posterior del hardware de máquina virtual (vSphere 5.5 o posterior)</Msg>
    <Msg ovf:msgid="config.medium.label">Mediano</Msg>
    <Msg ovf:msgid="config.medium.description">
IMPORTANTE: Esta configuración es compatible con la implementación de producción de Local Manager (función de 'NSX Manager').
           Es compatible con la implementación de producción de Global Manager

Esta configuración requiere lo siguiente:
* 6 vCPU
* 24GB de RAM
* 300GB de almacenamiento
* Versión 10 o posterior del hardware de máquina virtual (vSphere 5.5 o posterior)</Msg>
    <Msg ovf:msgid="config.large.label">Grande</Msg>
    <Msg ovf:msgid="config.large.description">
IMPORTANTE: Esta configuración es compatible con la implementación de producción de Local Manager (función de 'NSX Manager').
           Es compatible con la implementación de producción de Global Manager

Esta configuración requiere lo siguiente:
* 12 vCPU
* 48GB de RAM
* 300GB de almacenamiento
* Versión 10 o posterior del hardware de máquina virtual (vSphere 5.5 o posterior)</Msg>
    <Msg ovf:msgid="config.xlarge.label">Extragrande</Msg>
    <Msg ovf:msgid="config.xlarge.description">
IMPORTANTE: Esta configuración es compatible con la implementación de producción de Local Manager (función de 'NSX Manager').
           Es compatible con la implementación de producción de Global Manager

Esta configuración requiere lo siguiente:
* 24 vCPU
* 96GB de RAM
* 400GB de almacenamiento
* Versión 10 o posterior del hardware de máquina virtual (vSphere 5.5 o posterior)</Msg>
    <Msg ovf:msgid="grub.password.label">Contraseña de usuario raíz de GRUB del sistema</Msg>
    <Msg ovf:msgid="grub.password.desc">La contraseña del usuario raíz de GRUB para esta máquina virtual.</Msg>
    <Msg ovf:msgid="grub.menu.timeout.label">Tiempo de espera del menú de GRUB del sistema</Msg>
    <Msg ovf:msgid="grub.menu.timeout.desc">El tiempo de espera para mostrar el menú de GRUB de esta máquina virtual.</Msg>
    <Msg ovf:msgid="root.user.password.label">Contraseña de usuario raíz del sistema</Msg>
    <Msg ovf:msgid="root.user.password.desc">La contraseña del usuario raíz de esta máquina virtual.
Siga la regla de complejidad de contraseña como se indica a continuación:
    - longitud mínima de 8 caracteres
    - &gt;=1 carácter en mayúscula
    - &gt;=1 carácter en minúscula
    - &gt;=1 carácter numérico
    - &gt;=1 carácter especial
    - &gt;=5 caracteres únicos
    - reglas de complejidad de contraseña predeterminadas aplicadas por el módulo PAM de Linux
    NOTA: La validación de la seguridad de la contraseña se producirá durante el arranque de la máquina virtual. Si la contraseña no cumple los criterios anteriores, inicie sesión como usuario raíz para que aparezca la solicitud de cambio de contraseña. </Msg>
    <Msg ovf:msgid="cli.user.password.label">Contraseña de usuario "admin" de CLI</Msg>
    <Msg ovf:msgid="cli.user.password.desc">La contraseña del usuario de la CLI predeterminado para esta máquina virtual.
Siga la regla de complejidad de contraseña como se indica a continuación:
    - longitud mínima de 8 caracteres
    - &gt;=1 carácter en mayúscula
    - &gt;=1 carácter en minúscula
    - &gt;=1 carácter numérico
    - &gt;=1 carácter especial
    - &gt;=5 caracteres únicos
    - reglas de complejidad de contraseña predeterminadas aplicadas por el módulo PAM de Linux
    NOTA: La validación de la seguridad de la contraseña se producirá durante el arranque de la máquina virtual. Si la contraseña no cumple los criterios anteriores, inicie sesión como usuario admin para que aparezca la solicitud de cambio de contraseña. </Msg>
    <Msg ovf:msgid="cli.audit.user.password.label">Contraseña de usuario "audit" de CLI</Msg>
    <Msg ovf:msgid="cli.audit.user.password.desc">La contraseña del usuario audit de la CLI para esta máquina virtual.
Siga la regla de complejidad de contraseña como se indica a continuación:
    - longitud mínima de 8 caracteres
    - &gt;=1 carácter en mayúscula
    - &gt;=1 carácter en minúscula
    - &gt;=1 carácter numérico
    - &gt;=1 carácter especial
    - &gt;=5 caracteres únicos
    - reglas de complejidad de contraseña predeterminadas aplicadas por el módulo PAM de Linux
    NOTA: La validación de la seguridad de la contraseña se producirá durante el arranque de la máquina virtual. Si la contraseña no cumple los criterios anteriores, inicie sesión como usuario admin y use el comando de la CLI de NSX "set user audit" para cambiar la contraseña del usuario audit. </Msg>
    <Msg ovf:msgid="cli.user.adminusername.label">Nombre de usuario "admin" de la CLI (predeterminado: admin)</Msg>
    <Msg ovf:msgid="cli.user.adminusername.desc">Nombre de usuario del usuario administrador.</Msg>
    <Msg ovf:msgid="cli.user.auditusername.label">Nombre de usuario "audit" de la CLI (predeterminado: audit)</Msg>
    <Msg ovf:msgid="cli.user.auditusername.desc">Nombre de usuario del auditor.</Msg>
    <Msg ovf:msgid="extraPara.label">Parámetros opcionales</Msg>
    <Msg ovf:msgid="extraPara.desc">Solo para uso interno.</Msg>
    <Msg ovf:msgid="network.ipv4.category">Propiedades de red</Msg>
    <Msg ovf:msgid="hostname.label">Nombre de host</Msg>
    <Msg ovf:msgid="hostname.desc">El nombre de host de esta máquina virtual.
    Los caracteres válidos para el nombre de host son A-Z, a-z, 0-9, punto (.) y guion (-). El nombre del host no puede comenzar con un guion. Cada elemento del nombre de host debe tener entre 1 y 63 caracteres, y el nombre de host completo, incluidos los puntos, puede tener una longitud máxima de 253 caracteres.
    NOTA: Si el nombre de host contiene caracteres no válidos, el dispositivo se implementará con el nombre de host 'nsx-manager'.</Msg>
    <Msg ovf:msgid="nsx_role.label">Nombre de función</Msg>
    <Msg ovf:msgid="nsx_role.desc">La función de esta máquina virtual. Actualmente se admiten 'NSX Global Manager' o 'NSX Manager' como nombre de función.</Msg>
    <Msg ovf:msgid="network.ipv4.address.label">Dirección IPv4 de la red de administración</Msg>
    <Msg ovf:msgid="network.ipv4.address.desc">La dirección IPv4 de la primera interfaz. Para las implementaciones de solo IPv6, utilice el valor: Ninguno</Msg>
    <Msg ovf:msgid="network.ipv4.netmask.label">Máscara de red de red de administración</Msg>
    <Msg ovf:msgid="network.ipv4.netmask.desc">La máscara de red de la primera interfaz. Para las implementaciones de solo IPv6, utilice el valor: Ninguno</Msg>
    <Msg ovf:msgid="network.ipv4.gateway.label">Puerta de enlace IPv4 predeterminada</Msg>
    <Msg ovf:msgid="network.ipv4.gateway.desc">La puerta de enlace IPv4 predeterminada de esta máquina virtual.</Msg>
    <Msg ovf:msgid="network.ipv6.address.label">Dirección IPv6 de la red de administración</Msg>
    <Msg ovf:msgid="network.ipv6.address.desc">La dirección IPv6 para la primera interfaz.</Msg>
    <Msg ovf:msgid="network.ipv6.netmask.label">Prefijo de máscara de red de red IPv6 de administración</Msg>
    <Msg ovf:msgid="network.ipv6.netmask.desc">El prefijo de máscara de red IPv6 para la primera interfaz. (p. ej.- 64)</Msg>
    <Msg ovf:msgid="network.ipv6.gateway.label">Puerta de enlace IPv6 predeterminada</Msg>
    <Msg ovf:msgid="network.ipv6.gateway.desc">La puerta de enlace IPv6 predeterminada de esta máquina virtual.</Msg>
    <Msg ovf:msgid="dns.category">DNS</Msg>
    <Msg ovf:msgid="dns.primary.label">Lista de servidores DNS</Msg>
    <Msg ovf:msgid="dns.primary.desc">La lista de servidores DNS separados por espacios para esta máquina virtual (válida solo si se especifica una dirección IPv4 para la primera interfaz).
    NOTA: Se pueden configurar como máximo tres servidores de nombres (se utilizarán los primeros 3 servidores de nombres de la lista y los demás se ignorarán).</Msg>
    <Msg ovf:msgid="dns.domain.label">Lista de búsqueda de dominios</Msg>
    <Msg ovf:msgid="dns.domain.desc">La lista de búsqueda de dominios separados por espacios para esta máquina virtual (válida solo si se especifica una dirección IPv4 para la primera interfaz).</Msg>
    <Msg ovf:msgid="services.configuration.category">Configuración de servicios</Msg>
    <Msg ovf:msgid="ntp.label">Lista de servidores NTP</Msg>
    <Msg ovf:msgid="ntp.desc">La lista de servidores NTP (separados por espacios) para esta máquina virtual.</Msg>
    <Msg ovf:msgid="ssh.enable.label">Habilitar SSH</Msg>
    <Msg ovf:msgid="ssh.enable.desc">No se recomienda habilitar el servicio SSH por motivos de seguridad.</Msg>
    <Msg ovf:msgid="ssh.allowrootlogin.label">Permitir inicios de sesión SSH de raíz</Msg>
    <Msg ovf:msgid="ssh.allowrootlogin.desc">No se recomienda permitir inicios de sesión SSH raíz por motivos de seguridad.</Msg>
    <Msg ovf:msgid="ssh.softwareintchecker.label">Comprobación de integridad de software</Msg>
    <Msg ovf:msgid="ssh.softwareintchecker.desc">La comprobación de integridad de software solo es necesaria para NDCPP 2.2</Msg>
    <Msg ovf:msgid="internal.properties.category">Propiedades internas: no modifique estos parámetros.</Msg>
    <Msg ovf:msgid="mpIp.label">IP de Manager</Msg>
    <Msg ovf:msgid="mpIp.desc">Solo para uso interno. No establezca este parámetro.</Msg>
    <Msg ovf:msgid="mpToken.label">Token de Manager</Msg>
    <Msg ovf:msgid="mpToken.desc">Solo para uso interno. No establezca este parámetro.</Msg>
    <Msg ovf:msgid="mpThumbprint.label">Huella digital del administrador</Msg>
    <Msg ovf:msgid="mpThumbprint.desc">Solo para uso interno. No establezca este parámetro.</Msg>
    <Msg ovf:msgid="mpNodeId.label">ID de nodo de Manager</Msg>
    <Msg ovf:msgid="mpNodeId.desc">Solo para uso interno. No establezca este parámetro.</Msg>
    <Msg ovf:msgid="mpClusterId.label">Identificador de clúster del primer clúster de Manager</Msg>
    <Msg ovf:msgid="mpClusterId.desc">Solo para uso interno. No establezca este parámetro.</Msg>
</Strings>
