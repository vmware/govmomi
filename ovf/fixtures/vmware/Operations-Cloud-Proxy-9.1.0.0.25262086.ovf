;,&quot;Turkey&quot;,&quot;UCT&quot;,&quot;Universal&quot;,&quot;US/Alaska&quot;,&quot;US/Aleutian&quot;,&quot;US/Arizona&quot;,&quot;US/Central&quot;,&quot;US/East-Indiana&quot;,&quot;US/Eastern&quot;,&quot;US/Hawaii&quot;,&quot;US/Indiana-Starke&quot;,&quot;US/Michigan&quot;,&quot;US/Mountain&quot;,&quot;US/Pacific&quot;,&quot;US/Samoa&quot;,&quot;UTC&quot;,&quot;W-SU&quot;,&quot;WET&quot;,&quot;Zulu&quot;}">
