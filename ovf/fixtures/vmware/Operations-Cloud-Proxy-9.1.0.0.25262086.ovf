    <Msg ovf:msgid="application.otk.label">Unique Registration Key</Msg>
    <Msg ovf:msgid="application.otk.description">You can get the unique registration key as follows:
        1.     Open VMware Cloud Foundation Operations service.
        2.     Navigate to Administration &gt; Cloud Proxies &gt; ADD.
        3.     Copy the generated unique registration key.</Msg>
    <Msg ovf:msgid="application.friendly.name.label">Friendly Name</Msg>
    <Msg ovf:msgid="application.friendly.name.description">The user-friendly name for instance identification</Msg>
    <Msg ovf:msgid="application.docker.ip.range.label">Docker Subnet</Msg>
    <Msg ovf:msgid="application.docker.ip.range.description">Provide an IP range in CIDR format to create a network subnet for the Docker containers running inside this appliance. This will prevent any network overlap.</Msg>
    <Msg ovf:msgid="application.timezone.label">Timezone setting</Msg>
    <Msg ovf:msgid="application.timezone.description">Select the proper timezone setting for this VM or leave default Etc/UTC.</Msg>
    <Msg ovf:msgid="application.ntp.label">NTP servers list</Msg>
    <Msg ovf:msgid="application.ntp.description">The NTP Servers List (comma-separated) for this VM.</Msg>
    <Msg ovf:msgid="guestinfo.cis.appliance.ssh.label">Prevent disabling of SSH</Msg>
    <Msg ovf:msgid="guestinfo.cis.appliance.ssh.description">Use common passwords and setups.
        Ensure that sshd is configured and running.
        WARNING: Using this option will result in a less than
        fully secure installation.</Msg>
    <Msg ovf:msgid="guestinfo.cis.appliance.rc.label">Remote Collector</Msg>
    <Msg ovf:msgid="guestinfo.cis.appliance.rc.description">Automatically configure this node to be used as a remote collector.</Msg>
    <Msg ovf:msgid="application.ipv6.lable">IPv6</Msg>
    <Msg ovf:msgid="application.ipv6.description">Use IPv6. If IPv6 is not available configuration will not succeed.</Msg>
    <Msg ovf:msgid="network.proxy.settings">Network Proxy Settings</Msg>
    <Msg ovf:msgid="application.network.proxy.ip.label">Network Proxy IP Address</Msg>
    <Msg ovf:msgid="application.network.proxy.ip.description">Leave blank if no Network Proxy will be used</Msg>
    <Msg ovf:msgid="application.network.proxy.port.label">Network Proxy Port</Msg>
    <Msg ovf:msgid="application.network.proxy.port.description">Leave blank if no Network Proxy will be used</Msg>
    <Msg ovf:msgid="application.network.proxy.username.label">Network proxy user name</Msg>
    <Msg ovf:msgid="application.network.proxy.username.description">Leave blank if Network Proxy authentication is not required</Msg>
    <Msg ovf:msgid="application.network.proxy.password.label">Network Proxy password</Msg>
    <Msg ovf:msgid="application.network.proxy.password.description">Leave blank if Network Proxy authentication is not  required</Msg>
    <Msg ovf:msgid="application.ssl.label">SSL</Msg>
    <Msg ovf:msgid="application.ssl.description">Use SSL connection for Network Proxy</Msg>
    <Msg ovf:msgid="application.ssl.verification.label">Verify SSL cert</Msg>
    <Msg ovf:msgid="application.ssl.verification.description">Verify Network Proxy&apos;s SSL cert</Msg>
    <Msg ovf:msgid="application.custom.ca.label">Custom CA</Msg>
    <Msg ovf:msgid="application.custom.ca.description">Specify the custom CA</Msg>
    <Msg ovf:msgid="deployment.info">The list of deployment options</Msg>
    <Msg ovf:msgid="config.smallcp.label">Classic Small Cloud Proxy</Msg>
    <Msg ovf:msgid="config.smalcp.description">Use this configuration for environments upto 16000 VMs. This deployment will require 2 vCPUs and 8GB Memory for the vApp. For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Msg>
    <Msg ovf:msgid="config.standardcp.label">Classic Standard Cloud Proxy</Msg>
    <Msg ovf:msgid="config.standardcp.description">Use this configuration for environments between 16000 and 80000 VMs. This deployment will require 4 vCPUs and 32GB Memory for the vApp. For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Msg>
    <Msg ovf:msgid="config.smallunifiedcp.label">Unified Small Cloud Proxy</Msg>
    <Msg ovf:msgid="config.smallunifiedcp.description">Use this configuration for environments upto 16000 VMs. This deployment will require 4 vCPUs and 16GB Memory for the vApp. For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Msg>
    <Msg ovf:msgid="config.standardunifiedcp.label">Unified Standard Cloud Proxy</Msg>
    <Msg ovf:msgid="config.standardunifiedcp.description">Use this configuration for environments between 16000 and 80000 VMs. This deployment will require 8 vCPUs and 48GB Memory for the vApp.  For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Msg>
