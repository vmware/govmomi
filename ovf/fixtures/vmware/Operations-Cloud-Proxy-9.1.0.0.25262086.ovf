      <Property ovf:key="ntp.server.list" ovf:type="string" ovf:userConfigurable="true" ovf:value="">
        <Label ovf:msgid="application.ntp.label">NTP servers list</Label>
        <Description ovf:msgid="application.ntp.description">The NTP Servers List (comma-separated) for this VM.</Description>
      </Property>
      <Property ovf:key="guestinfo.cis.appliance.ssh.enabled" ovf:type="string" ovf:userConfigurable="false" ovf:value="false">
        <Label ovf:msgid="guestinfo.cis.appliance.ssh.label">Prevent disabling of SSH</Label>
        <Description ovf:msgid="guestinfo.cis.appliance.ssh.description">Use common passwords and setups.
              Ensure that sshd is configured and running.
              WARNING: Using this option will result in a less than
              fully secure installation.</Description>
      </Property>
      <Category ovf:msgid="network.proxy.settings">Network Proxy Settings</Category>
      <Property ovf:key="network_proxy_ip" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(0),MaxLen(65535)">
        <Label ovf:msgid="application.network.proxy.ip.label">Network Proxy IP Address</Label>
        <Description ovf:msgid="application.network.proxy.ip.description">Leave blank if no Network Proxy will be used</Description>
      </Property>
      <Property ovf:key="network_proxy_port" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(0),MaxLen(65535)">
        <Label ovf:msgid="application.network.proxy.port.label">Network Proxy Port</Label>
        <Description ovf:msgid="application.network.proxy.port.description">Leave blank if no Network Proxy will be used</Description>
      </Property>
      <Property ovf:key="network_proxy_username" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(0),MaxLen(65535)">
        <Label ovf:msgid="application.network.proxy.username.label">Network proxy user name</Label>
        <Description ovf:msgid="application.network.proxy.username.description">Leave blank if Network Proxy authentication is not required</Description>
      </Property>
      <Property ovf:key="network_proxy_password" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(0),MaxLen(65535)" ovf:password="true">
        <Label ovf:msgid="application.network.proxy.password.label">Network Proxy password</Label>
        <Description ovf:msgid="application.network.proxy.password.description">Leave blank if Network Proxy authentication is not  required</Description>
      </Property>
      <Property ovf:key="ssl" ovf:type="boolean" ovf:userConfigurable="true" ovf:value="false">
        <Label ovf:msgid="application.ssl.label">SSL</Label>
        <Description ovf:msgid="application.ssl.description">Use SSL connection for Network Proxy</Description>
      </Property>
      <Property ovf:key="ssl_verification" ovf:type="boolean" ovf:userConfigurable="true" ovf:value="false">
        <Label ovf:msgid="application.ssl.verification.label">Verify SSL cert</Label>
        <Description ovf:msgid="application.ssl.verification.description">Verify Network Proxy's SSL cert</Description>
      </Property>
      <Property ovf:key="load_balancer_ip" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(0),MaxLen(65535)">
        <Label ovf:msgid="application.load.balancer.ip.label">Load Balancer IP/FQDN</Label>
        <Description ovf:msgid="application.load.balancer.ip.description">VMware Cloud Foundation Operations Load Balancer IP/FQDN (If applicable). Applicable only for on-premises setups.</Description>
      </Property>
      <Property ovf:key="cprc_ca.default" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(0),MaxLen(65535)">
        <Label ovf:msgid="application.cprc.ca.label">Custom CA</Label>
        <Description ovf:msgid="application.cprc.ca.description">Specify the custom CA. To import multiple CAs, use the vApp options post deployment. For more details, refer to the documentation.</Description>
      </Property>
    </ProductSection>
    <ProductSection ovf:instance="VMware_Aria_Operations_Cloud_Proxy" ovf:required="false">
      <Info>Network Properties</Info>
      <Category>Networking Properties</Category>
      <Property ovf:key="domain" ovf:userConfigurable="true" ovf:type="string">
        <Label>Domain Name</Label>
        <Description>Domain this VM will be in. Leave blank if DHCP is desired.</Description>
      </Property>
      <Property ovf:key="searchpath" ovf:userConfigurable="true" ovf:type="string">
        <Label>Domain Search Path</Label>
        <Description>The domain search path (comma or space separated domain names) for this VM. Leave blank if DHCP is desired.</Description>
      </Property>
      <Property ovf:key="DNS" ovf:userConfigurable="true" ovf:type="string">
        <Label>Domain Name Servers</Label>
        <Description>The domain name server IP Addresses for this VM (comma separated). Leave blank if DHCP is desired.</Description>
      </Property>
      <Category>IPv4 configuration</Category>
      <Property ovf:key="ipv4_type" ovf:type="string" ovf:userConfigurable="true" ovf:value="DHCP" ovf:qualifiers="ValueMap{&quot;DHCP&quot;,&quot;Static&quot;,&quot;Disabled&quot;}">
        <Label>IPv4 Type</Label>
        <Description>Select the IPv4 type. Fill the below fiellds only if "Static" option has been selected.</Description>
      </Property>
      <Property ovf:key="ipv4_address" ovf:userConfigurable="true" ovf:type="string">
        <Label>IPv4 network IP Address</Label>
        <Description>The IPv4 address for this interface. Leave blank if DHCP is desired.</Description>
      </Property>
      <Property ovf:key="ipv4_gateway" ovf:userConfigurable="true" ovf:type="string">
        <Label>IPv4 default Gateway</Label>
        <Description>The IPv4 default gateway address for this VM. Leave blank if DHCP is desired.</Description>
      </Property>
      <Property ovf:key="ipv4_netmask" ovf:userConfigurable="true" ovf:type="string">
        <Label>IPv4 network Netmask</Label>
        <Description>The IPv4 netmask or prefix for this interface. Leave blank if DHCP is desired.</Description>
      </Property>
      <Category>IPv6 configuration</Category>
      <Property ovf:key="forceIpv6" ovf:type="boolean" ovf:userConfigurable="true" ovf:value="false">
        <Label>Prefer IPv6</Label>
        <Description>Prefer IPv6 Connectivity: When enabled, the system will prioritize IPv6 addresses over IPv4 when both are available.</Description>
      </Property>
      <Property ovf:key="ipv6_type" ovf:type="string" ovf:userConfigurable="true" ovf:value="DHCP/Slaac" ovf:qualifiers="ValueMap{&quot;DHCP/Slaac&quot;,&quot;Static&quot;,&quot;Disabled&quot;}">
        <Label>IPv6 Type</Label>
        <Description>Select the IPv6 type. Fill the below fiellds only if "Static" option has been selected.</Description>
      </Property>
      <Property ovf:key="ipv6_address" ovf:userConfigurable="true" ovf:type="string">
        <Label>IPv6 network IP Address</Label>
        <Description>The IPv6 address for this interface. Leave blank if DHCP or Slaac is desired.</Description>
      </Property>
      <Property ovf:key="ipv6_gateway" ovf:userConfigurable="true" ovf:type="string">
        <Label>IPv6 default Gateway</Label>
        <Description>The IPv6 default gateway address for this VM. Leave blank if DHCP or Slaac is desired.</Description>
      </Property>
      <Property ovf:key="ipv6_netmask" ovf:userConfigurable="true" ovf:type="string">
        <Label>IPv6 network Netmask</Label>
        <Description>The IPv6 netmask or prefix for this interface. Leave blank if DHCP or Slaac is desired.</Description>
      </Property>
    </ProductSection>
    <ProductSection ovf:class="vm" ovf:required="false">
      <Info>VM specific properties</Info>
      <Property ovf:key="vmname" ovf:type="string" ovf:value="VMware_Aria_Operations_Cloud_Proxy"/>
    </ProductSection>
