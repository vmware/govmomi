    <ProductSection ovf:required="false">
      <Info ovf:msgid="product.info">Appliance ISV branding information</Info>
      <Product ovf:msgid="product.product">VMware Aria Operations Cloud Proxy</Product>
      <Vendor ovf:msgid="product.vendor">Broadcom Inc.</Vendor>
      <!--
            Version is the actual product version in the
            form X.X.X.X where X is an unsigned 16-bit integer.

            FullVersion is a descriptive version string
            including, for example, alpha or beta designations
            and other release criteria.
        -->
      <Version>9.1.0.0</Version>
      <FullVersion>9.1.0.0 Build 25262086</FullVersion>
      <ProductUrl/>
      <VendorUrl>http://www.broadcom.com</VendorUrl>
      <AppUrl>https://${vami.ip0.VMware_Aria_Operations_Cloud_Proxy}/</AppUrl>
      <Category ovf:msgid="cloudproxy.configurations">Cloud Proxy Configurations</Category>
      <Property ovf:key="root_password" ovf:password="true" ovf:qualifiers="MinLen(15),MaxLen(65535)" ovf:type="string" ovf:userConfigurable="true">
        <Label ovf:msgid="root_password.label">Enter root user Password</Label>
        <Description ovf:msgid="root_password.description">
        This will be used as an initial password for the root user account. Password must be at least 15 characters long, containing a minimum of one digit, one uppercase letter, one lowercase letter, and one special character. The password must not contain the username, and will be checked against the cracklib dictionary for strength.
        </Description>
      </Property>
      <Property ovf:key="otk" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(8),MaxLen(65535)">
        <Label ovf:msgid="application.otk.label">Unique Registration Key</Label>
        <Description ovf:msgid="application.otk.description">You can get the unique registration key as follows:
      1.     Open VMware Aria Operations service.
      2.     Navigate to Administration &gt; Cloud Proxies &gt; ADD.
      3.     Copy the generated unique registration key.</Description>
      </Property>
      <Property ovf:key="docker_ip_range" ovf:type="string" ovf:userConfigurable="true" ovf:value="" ovf:qualifiers="MinLen(0),MaxLen(65535)">
        <Label ovf:msgid="application.docker.ip.range.label">Docker Subnet</Label>
        <Description ovf:msgid="application.docker.ip.range.description">Provide an IP range in CIDR format to create a network subnet for the Docker containers running inside this appliance. This will prevent any network overlap.</Description>
      </Property>
      <Property ovf:key="friendly.name" ovf:type="string" ovf:userConfigurable="true" ovf:value="">
        <Label ovf:msgid="application.friendly.name.label">Friendly Name</Label>
        <Description ovf:msgid="application.friendly.name.description">The user-friendly name for instance identification</Description>
      </Property>
