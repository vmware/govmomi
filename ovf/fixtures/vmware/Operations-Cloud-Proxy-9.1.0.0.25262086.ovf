  <DeploymentOptionSection xml:lang="en">
    <Info ovf:msgid="deployment.info">The list of deployment options</Info>
    <Configuration ovf:id="smallcp">
      <Label ovf:msgid="config.smallcp.label">Classic Small Cloud Proxy</Label>
      <Description ovf:msgid="config.smalcp.description">Use this configuration for environments upto 16000 VMs. This deployment will require 2 vCPUs and 8GB Memory for the vApp. For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Description>
    </Configuration>
    <Configuration ovf:id="standardcp">
      <Label ovf:msgid="config.standardcp.label">Classic Standard Cloud Proxy</Label>
      <Description ovf:msgid="config.standardcp.description">Use this configuration for environments between 16000 and 80000 VMs. This deployment will require 4 vCPUs and 32GB Memory for the vApp. For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Description>
    </Configuration>
    <Configuration ovf:id="smallunifiedcp">
      <Label ovf:msgid="config.smallunifiedcp.label">Unified Small Cloud Proxy</Label>
      <Description ovf:msgid="config.smallunifiedcp.description">Use this configuration for environments upto 16000 VMs. This deployment will require 4 vCPUs and 16GB Memory for the vApp. For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Description>
    </Configuration>
    <Configuration ovf:id="standardunifiedcp">
      <Label ovf:msgid="config.standardunifiedcp.label">Unified Standard Cloud Proxy</Label>
      <Description ovf:msgid="config.standardunifiedcp.description">Use this configuration for environments between 16000 and 80000 VMs. This deployment will require 8 vCPUs and 48GB Memory for the vApp.  For more detailed sizing information please see  https://knowledge.broadcom.com/external/article?articleNumber=324340</Description>
    </Configuration>
  </DeploymentOptionSection>
