    <References>
        <File ovf:id="file1" ovf:href="../../../vmdk/dummy.vmdk" ovf:size="236243728"/>
    </References>
    <Section xsi-namespace:type="ovf:DiskSection_Type">
        <Info>Describes the set of virtual disks</Info>
        <Disk ovf:diskId="vmdisk1" ovf:fileRef="file1" ovf:capacity="1073741824" ovf:format="http://www.vmware.com/specifications/vmdk.html#sparse" />
    </Section>
     <Content xsi-namespace:type="ovf:VirtualSystem_Type" ovf:id="PTC01_VM">
