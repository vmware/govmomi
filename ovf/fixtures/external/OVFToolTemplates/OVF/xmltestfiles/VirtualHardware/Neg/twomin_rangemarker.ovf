<?xml version="1.0" encoding="utf-8"?>
<ovf:Envelope xmlns:xsi-namespace="http://www.w3.org/2001/XMLSchema-instance" xmlns:ovf="http://www.vmware.com/schema/ovf/1/envelope" xmlns:vssd-namespace="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_VirtualSystemSettingData" xmlns:rasd-namespace="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData" ovf:version="0.9">
    <References>
        <File ovf:id="file1" ovf:href="../../../vmdk/valid_disk.vmdk" ovf:size="8589934592"/>
    </References>
    <Section xsi-namespace:type="ovf:DiskSection_Type">
        <Info>Describes the set of virtual disks</Info>
        <Disk ovf:diskId="vmdisk1" ovf:fileRef="file1" ovf:capacity="8589934592" ovf:format="http://www.vmware.com/specifications/vmdk.html#sparse" />
    </Section>
     <Content xsi-namespace:type="ovf:VirtualSystem_Type" ovf:id="PTC01_VM">
        <Info>The virtual machince "ArchLinux"</Info>
        <Section xsi-namespace:type="ovf:OperatingSystemSection_Type" ovf:id="36">
            <Info>Guest Operating System</Info>
            <Description>Other Linux (32-bit)</Description>
        </Section>
	<Section xsi-namespace:type="ovf:VirtualHardwareSection_Type" ovf:required="true">
            <Info>512 MB , 1 CPU, 1 disk, 1 nic</Info>
            <System>
                <vssd-namespace:InstanceId>0</vssd-namespace:InstanceId>
                <vssd-namespace:VirtualSystemIdentifier>system id</vssd-namespace:VirtualSystemIdentifier>
                <vssd-namespace:VirtualSystemType>vmx-04 xen-3</vssd-namespace:VirtualSystemType>
            </System>
	    <Item ovf:required="true">
                <rasd-namespace:Caption>Hard Disk 1</rasd-namespace:Caption>
                <rasd-namespace:Description />
		<rasd-namespace:InstanceId>6</rasd-namespace:InstanceId>
                <rasd-namespace:ResourceType>17</rasd-namespace:ResourceType>
                <rasd-namespace:HostResource>/disk/vmdisk1</rasd-namespace:HostResource>
                <rasd-namespace:Parent>8</rasd-namespace:Parent>
                <rasd-namespace:AddressOnParent>0</rasd-namespace:AddressOnParent>
            </Item>
	     <Item>
                <rasd-namespace:Caption>512MB of memory</rasd-namespace:Caption>
                <rasd-namespace:Description>Memory Size</rasd-namespace:Description>
                <rasd-namespace:InstanceId>2</rasd-namespace:InstanceId>
                <rasd-namespace:ResourceType>4</rasd-namespace:ResourceType>
                <rasd-namespace:AllocationUnits>MegaBytes</rasd-namespace:AllocationUnits>
                <rasd-namespace:VirtualQuantity>512</rasd-namespace:VirtualQuantity>
            </Item>
	    <Item ovf:bound="min">
                <rasd-namespace:Caption>384MB of memory</rasd-namespace:Caption>
                <rasd-namespace:Description>Memory Size</rasd-namespace:Description>
	        <rasd-namespace:InstanceId>2</rasd-namespace:InstanceId>
		<rasd-namespace:ResourceType>4</rasd-namespace:ResourceType>
                <rasd-namespace:AllocationUnits>MegaBytes</rasd-namespace:AllocationUnits>
		<rasd-namespace:Reservation>384</rasd-namespace:Reservation>
            </Item>
	    <Item ovf:bound="min">
                <rasd-namespace:Caption>200MB of memory</rasd-namespace:Caption>
                <rasd-namespace:Description>Memory Size</rasd-namespace:Description>
	        <rasd-namespace:InstanceId>2</rasd-namespace:InstanceId>
		<rasd-namespace:ResourceType>4</rasd-namespace:ResourceType>
                <rasd-namespace:AllocationUnits>MegaBytes</rasd-namespace:AllocationUnits>
		<rasd-namespace:Reservation>200</rasd-namespace:Reservation>
            </Item>
	    <Item ovf:required="true">
                <rasd-namespace:Caption>SCSI Controller 0</rasd-namespace:Caption>
                <rasd-namespace:Description>LsiLogic SCSI Controller</rasd-namespace:Description>
                <rasd-namespace:InstanceId>8</rasd-namespace:InstanceId>
                <rasd-namespace:ResourceType>6</rasd-namespace:ResourceType>
                <rasd-namespace:ResourceSubType>buslogic,lsilogic</rasd-namespace:ResourceSubType>
                <rasd-namespace:BusNumber>0</rasd-namespace:BusNumber>
            </Item>
        </Section>
     </Content>
</ovf:Envelope>