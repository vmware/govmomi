<?xml version="1.0" encoding="UTF-8"?>
<Envelope
    xmlns="http://schemas.dmtf.org/ovf/envelope/1" 
    xmlns:cim="http://schemas.dmtf.org/wbem/wscim/1/common" 
    xmlns:ovf="http://schemas.dmtf.org/ovf/envelope/1" 
    xmlns:rasd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData" 
    xmlns:vmw="http://www.vmware.com/schema/ovf" 
    xmlns:vssd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_VirtualSystemSettingData" 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <References>
  </References>

  <DiskSection>
    <Info>Meta-information about the virtual disks</Info>
  </DiskSection>

  <NetworkSection>
    <Info>The list of logical networks</Info>
    <Network ovf:name="Network">
      <Description>The network that the SugarCRM application will be available on</Description>
    </Network>
  </NetworkSection>

  <vmw:IpAssignmentSection ovf:required="false" 
	   	           vmw:protocols="IPv4" 
   		           vmw:schemes="ovfenv,dhcp">
    <Info>Supported IP assignment schemes</Info>
  </vmw:IpAssignmentSection>

  <DeploymentOptionSection>
    <Info>The list of deployment options</Info>
    <Configuration ovf:id="small">
      <Label>Evaluation</Label>
      <Description>Use this configuration for evaluation purposes only. The number of CPUs required and amount of memory used is minimized, making it possible to run the system on a desktop system.</Description>
    </Configuration>
    <Configuration ovf:id="medium">
      <Label>Production</Label>
      <Description>Standard settings for a typical product environment. This deployment option is suitable for a SMB production environment with less than 500 users.
      </Description>
    </Configuration>
    <Configuration ovf:id="large">
     <Label>Enterprise</Label>
     <Description>Settings for large enterprise production environments. This deployment option is suitable for a large enterprise production environment with more than 500 users.
     </Description>
    </Configuration>
   </DeploymentOptionSection>

  <VirtualSystemCollection ovf:id="SugarCRM">
    <Info>A virtual service</Info>
    <Name>SugarCRM Solution</Name>

    <StartupSection>
      <Info>The startup order</Info>
      <Item ovf:id="web" 
	    ovf:order="2" 
	    ovf:startAction="powerOn" ovf:startDelay="370" ovf:waitingForGuest="true"
            ovf:stopAction="guestShutdown" ovf:stopDelay="370"/>
      <Item ovf:id="db" 
	    ovf:order="1" 
	    ovf:startAction="powerOn" ovf:startDelay="400" ovf:waitingForGuest="true"
	   ovf:stopAction="guestShutdown" ovf:stopDelay="400"/>
    </StartupSection>

    <!-- Example Custom Section -->
    <eg:AvailabilitySection ovf:required="false" 
	xmlns="http://www.example.com/ovf/" 
	xmlns:eg="http://www.example.com/ovf/">
       <ovf:Info>Anti-affinity Configuration for SugarCRM</ovf:Info>
       <AntiAffinity>
      	   <Item eg:id="web"/>
	   <Item eg:id="db"/>	
	</AntiAffinity>
    </eg:AvailabilitySection>	

    <AnnotationSection>
      <Info>A human-readable annotation</Info>
      <Annotation>The sweet way to manage customer relationships.</Annotation>
    </AnnotationSection>

    <ProductSection>
      <Info>Information about the installed software</Info>
      <Product>SugarCRM</Product>
      <Vendor>SugarCRM Inc</Vendor>
      <Version>4.5.1e</Version>
      <FullVersion>4.5.1e-build 131</FullVersion>
      <ProductUrl>http://www.sugarcrm.com/crm/products/crm-products.html</ProductUrl>
      <VendorUrl>http://www.sugarcrm.com/crm/</VendorUrl>
      <AppUrl>http://${webIp}/crm</AppUrl>
    </ProductSection>

    <EulaSection>
      <Info>An end-user license agreement</Info>	
      <License ovf:msgid="eula">SugarCRM Professional Subscription Agreement 
                               stored in external message bundle 
      </License>
    </EulaSection>

    <ResourceAllocationSection>
       <Info>CPU and Memory Reservations</Info>
       <Item ovf:configuration="large">
          <rasd:AllocationUnits>hertz * 10^9</rasd:AllocationUnits>
          <rasd:ElementName>CPU Reservation for the large configuration</rasd:ElementName>
          <rasd:InstanceID>cpuRes</rasd:InstanceID>
          <rasd:Reservation>1</rasd:Reservation>
          <rasd:ResourceType>3</rasd:ResourceType>
       </Item>

       <Item ovf:configuration="large">
	  <rasd:AllocationUnits>byte * 2 ^ 20</rasd:AllocationUnits>
	  <rasd:ElementName>512MB reservation for the large configuration</rasd:ElementName>
	  <rasd:InstanceID>memRes</rasd:InstanceID>
	  <rasd:Reservation>512</rasd:Reservation>
	  <rasd:ResourceType>4</rasd:ResourceType>
      </Item>
    </ResourceAllocationSection>

    <VirtualSystem ovf:id="web">
      <Info>A virtual machine</Info>
      <Name>SugarmCRM Server</Name>

      <OperatingSystemSection ovf:id="93">
        <Info>The kind of installed guest operating system</Info>
        <Description>Ubuntu</Description>
      </OperatingSystemSection>

      <ProductSection>
      	<Info>Property configuration</Info>
      </ProductSection>

      <VirtualHardwareSection ovf:transport="iso">
        <Info>Virtual hardware requirements</Info>
        <System>
          <vssd:ElementName>VMware Virtual Hardware Family 4</vssd:ElementName>
          <vssd:InstanceID>0</vssd:InstanceID>
          <vssd:VirtualSystemIdentifier>web</vssd:VirtualSystemIdentifier>
          <vssd:VirtualSystemType>vmx-04</vssd:VirtualSystemType>
        </System>
        <Item>
          <rasd:Description>Number of Virtual CPUs</rasd:Description>
          <rasd:ElementName>1 virtual CPU(s)</rasd:ElementName>
          <rasd:InstanceID>1</rasd:InstanceID>
          <rasd:ResourceType>3</rasd:ResourceType>
          <rasd:VirtualQuantity>1</rasd:VirtualQuantity>
        </Item>

        <Item configuration = "large">
          <rasd:Description>Number of Virtual CPUs</rasd:Description>
          <rasd:ElementName>2 virtual CPU(s) for large setup</rasd:ElementName>
          <rasd:InstanceID>1</rasd:InstanceID>
          <rasd:ResourceType>3</rasd:ResourceType>
          <rasd:VirtualQuantity>2</rasd:VirtualQuantity>
        </Item>

        <Item>
          <rasd:AllocationUnits>byte * 2^20</rasd:AllocationUnits>
          <rasd:Description>Memory Size</rasd:Description>
          <rasd:ElementName>256MB of memory</rasd:ElementName>
          <rasd:InstanceID>2</rasd:InstanceID>
          <rasd:ResourceType>4</rasd:ResourceType>
          <rasd:VirtualQuantity>256</rasd:VirtualQuantity>
        </Item>

	<Item ovf:configuration="medium large">
	  <rasd:ElementName>512MB configuration for medium setup</rasd:ElementName>
	  <rasd:InstanceID>2</rasd:InstanceID>
	  <rasd:ResourceType>4</rasd:ResourceType>
	  <rasd:VirtualQuantity>512</rasd:VirtualQuantity>
	  <rasd:Weight>150</rasd:Weight>
	</Item>

	<Item ovf:configuration="large">
	  <rasd:AllocationUnits>byte * 2 ^ 30</rasd:AllocationUnits>
	  <rasd:ElementName>1GB Memory configuration for large setup</rasd:ElementName>
	  <rasd:InstanceID>2</rasd:InstanceID>
	  <rasd:ResourceType>4</rasd:ResourceType>
	  <rasd:VirtualQuantity>1</rasd:VirtualQuantity>
	</Item>
	
        <Item>
          <rasd:Address>0</rasd:Address>
          <rasd:Description>SCSI Controller</rasd:Description>
          <rasd:ElementName>SCSI Controller 0</rasd:ElementName>
          <rasd:InstanceID>3</rasd:InstanceID>
          <rasd:ResourceSubType>lsilogic</rasd:ResourceSubType>
          <rasd:ResourceType>6</rasd:ResourceType>
        </Item>
        <Item>
          <rasd:Address>0</rasd:Address>
          <rasd:Description>IDE Controller</rasd:Description>
          <rasd:ElementName>IDE 0</rasd:ElementName>
          <rasd:InstanceID>5</rasd:InstanceID>
          <rasd:ResourceType>5</rasd:ResourceType>
        </Item>
        <Item>
          <rasd:AddressOnParent>0</rasd:AddressOnParent>
          <rasd:AutomaticAllocation>false</rasd:AutomaticAllocation>
          <rasd:ElementName>CD/DVD Drive 1</rasd:ElementName>
          <rasd:InstanceID>6</rasd:InstanceID>
          <rasd:Parent>5</rasd:Parent>
          <rasd:ResourceType>15</rasd:ResourceType>
        </Item>
        <Item>
          <rasd:AddressOnParent>7</rasd:AddressOnParent>
          <rasd:AutomaticAllocation>true</rasd:AutomaticAllocation>
          <rasd:Connection>Network</rasd:Connection>
          <rasd:Description>PCNet32 ethernet adapter</rasd:Description>
          <rasd:ElementName>Network Adapter 1</rasd:ElementName>
          <rasd:InstanceID>7</rasd:InstanceID>
          <rasd:ResourceSubType>PCNet32</rasd:ResourceSubType>
          <rasd:ResourceType>10</rasd:ResourceType>
        </Item>
      </VirtualHardwareSection>
    </VirtualSystem>

    <VirtualSystem ovf:id="db">
      <Info>A virtual machine</Info>
      <Name>Database Server</Name>

      <OperatingSystemSection ovf:id="93">
        <Info>The kind of installed guest operating system</Info>
        <Description>Ubuntu</Description>
      </OperatingSystemSection>

      <ProductSection>
	<Info>Property configuration</Info>
	<Property ovf:key="ip" ovf:type="string" ovf:value="${dbIp}"/>
      </ProductSection>

      <VirtualHardwareSection ovf:transport="iso">
        <Info>Virtual hardware requirements</Info>
        <System>
	  <vssd:ElementName>VMware Virtual Hardware Family 4</vssd:ElementName>
          <vssd:InstanceID>0</vssd:InstanceID>
          <vssd:VirtualSystemIdentifier>db</vssd:VirtualSystemIdentifier>
          <vssd:VirtualSystemType>vmx-04</vssd:VirtualSystemType>
        </System>
        <Item>
          <rasd:AllocationUnits>hertz * 10^6</rasd:AllocationUnits>
          <rasd:Description>Number of Virtual CPUs</rasd:Description>
          <rasd:ElementName>1 virtual CPU(s)</rasd:ElementName>
          <rasd:InstanceId>1</rasd:InstanceId>
          <rasd:ResourceType>3</rasd:ResourceType>
          <rasd:VirtualQuantity>1</rasd:VirtualQuantity>
        </Item>

        <Item configuration = "large">
          <rasd:Description>Number of Virtual CPUs</rasd:Description>
          <rasd:ElementName>2 virtual CPU(s) for large setup</rasd:ElementName>
          <rasd:InstanceID>1</rasd:InstanceID>
          <rasd:ResourceType>3</rasd:ResourceType>
          <rasd:VirtualQuantity>2</rasd:VirtualQuantity>
        </Item>

        <Item>
          <rasd:AllocationUnits>byte * 2^20</rasd:AllocationUnits>
          <rasd:Description>Memory Size</rasd:Description>
          <rasd:ElementName>256MB of memory</rasd:ElementName>
          <rasd:InstanceID>2</rasd:InstanceID>
          <rasd:ResourceType>4</rasd:ResourceType>
          <rasd:VirtualQuantity>256</rasd:VirtualQuantity>
        </Item>

	<Item ovf:configuration="medium large">
	  <rasd:ElementName>512MB configuration for medium setup</rasd:ElementName>
	  <rasd:InstanceID>2</rasd:InstanceID>
	  <rasd:ResourceType>4</rasd:ResourceType>
	  <rasd:VirtualQuantity>512</rasd:VirtualQuantity>
	  <rasd:Weight>100</rasd:Weight>
	</Item>

	<Item ovf:configuration="large">
	  <rasd:AllocationUnits>byte * 2 ^ 30</rasd:AllocationUnits>
	  <rasd:ElementName>1GB Memory configuration for large setup</rasd:ElementName>
	  <rasd:InstanceID>2</rasd:InstanceID>
	  <rasd:ResourceType>4</rasd:ResourceType>
	  <rasd:VirtualQuantity>1</rasd:VirtualQuantity>
	</Item>
	
        <Item>
          <rasd:Address>0</rasd:Address>
          <rasd:Description>SCSI Controller</rasd:Description>
          <rasd:ElementName>SCSI Controller 0</rasd:ElementName>
          <rasd:InstanceID>3</rasd:InstanceID>
          <rasd:ResourceSubType>lsilogic</rasd:ResourceSubType>
          <rasd:ResourceType>6</rasd:ResourceType>
        </Item>
        <Item>
          <rasd:Address>0</rasd:Address>
          <rasd:Description>IDE Controller</rasd:Description>
          <rasd:ElementName>IDE 0</rasd:ElementName>
          <rasd:InstanceID>5</rasd:InstanceID>
          <rasd:ResourceType>5</rasd:ResourceType>
        </Item>
        <Item>
          <rasd:AddressOnParent>0</rasd:AddressOnParent>
          <rasd:AutomaticAllocation>false</rasd:AutomaticAllocation>
          <rasd:ElementName>CD/DVD Drive 1</rasd:ElementName>
          <rasd:InstanceID>6</rasd:InstanceID>
          <rasd:Parent>5</rasd:Parent>
          <rasd:ResourceType>15</rasd:ResourceType>
        </Item>
        <Item>
          <rasd:AddressOnParent>7</rasd:AddressOnParent>
          <rasd:AutomaticAllocation>true</rasd:AutomaticAllocation>
          <rasd:Connection>Network</rasd:Connection>
          <rasd:Description>PCNet32 ethernet adapter</rasd:Description>
          <rasd:ElementName>Network Adapter 1</rasd:ElementName>
          <rasd:InstanceID>7</rasd:InstanceID>
          <rasd:ResourceSubType>PCNet32</rasd:ResourceSubType>
          <rasd:ResourceType>10</rasd:ResourceType>
        </Item>
      </VirtualHardwareSection>
    </VirtualSystem>
  </VirtualSystemCollection>

  <Strings ovf:fileRef="eula"/>

</Envelope>
