<?xml version="1.0" encoding="UTF-8"?>
<Envelope
    xmlns="http://schemas.dmtf.org/ovf/envelope/1"
    xmlns:cim="http://schemas.dmtf.org/wbem/wscim/1/common"
    xmlns:ovf="http://schemas.dmtf.org/ovf/envelope/1"
    xmlns:rasd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData"
    xmlns:test="http://www.vmware.com/ovf/test"
    xmlns:vcd="http://www.vmware.com/vcloud"
    xmlns:vmw="http://www.vmware.com/schema/ovf"
    xmlns:ovf2="http://schemas.dmtf.org/ovf/envelope/2"
    xmlns:vssd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_VirtualSystemSettingData"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <References/>

    <vmw:TagBasedPlacementGroupSection vmw:id="group1" vmw:name="groupName" vmw:priority="0">
        <Info>Tag based placement policy for group of VMs</Info>
        <vmw:Description>Tag based placement policy for group1 tier</vmw:Description>
        <vmw:TagCategory vmw:name="Security Service" vmw:id="1"/>
        <vmw:TagValue vmw:name="TPM Enabled" vmw:id="1"/>
    </vmw:TagBasedPlacementGroupSection>

    <vmw:TagBasedPlacementGroupSection vmw:id="group2" vmw:name="groupName" vmw:priority="0">
        <Info>Tag based placement policy for group of VMs</Info>
        <vmw:Description>Tag based placement policy for group1 tier</vmw:Description>
        <vmw:TagCategory vmw:name="Cluster Type" vmw:id="2"/>
        <vmw:TagValue vmw:name="Production" vmw:id="2"/>
    </vmw:TagBasedPlacementGroupSection>

    <vmw:StorageGroupSection vmw:id="storage-group1" vmw:name="storage-Group1">
        <Info>Storage policy for group of disks</Info>
        <vmw:Description>Storage policy for group1 tier</vmw:Description>
    </vmw:StorageGroupSection>

    <vmw:StorageGroupSection vmw:id="storage-group2" vmw:name="storage-Group2">
        <Info>Storage policy for group of disks</Info>
        <vmw:Description>Storage policy for group2 tier</vmw:Description>
    </vmw:StorageGroupSection>

    <ovf2:PlacementGroupSection ovf:required="false" vmw:name="anti_affinity_group_80a11d57-1128-4957-b56b-250d17a06fd5" ovf2:id="vmware.pbm://39749a24-f8dd-47b9-a354-ad5c03892e2a/11d41766-0440-48b8-bbc8-45b57a4ebdb1" vmw:priority="0" vmw:policyId="vmware.pbm://39749a24-f8dd-47b9-a354-ad5c03892e2a/11d41766-0440-48b8-bbc8-45b57a4ebdb1" ovf2:policy="availability">
        <Info>Placement policy for group of VMs</Info>
        <ovf2:Description>AntiAffinity Group of Id vmware.pbm://39749a24-f8dd-47b9-a354-ad5c03892e2a/11d41766-0440-48b8-bbc8-45b57a4ebdb1</ovf2:Description>
    </ovf2:PlacementGroupSection>

    <VirtualSystemCollection ovf:id="vsc1">
        <Info>A virtual machine collection</Info>
        <Name>Test System Collection</Name>

	  <!-- Zero or more TagBasedPlacementSection may be used on VirtualSystemCollection -->
        <vmw:TagBasedPlacementSection vmw:group="group1">
            <Info>Tag based placement policy group reference</Info>
        </vmw:TagBasedPlacementSection>
        <vmw:TagBasedPlacementSection vmw:group="group2">
            <Info>Tag based placement policy group reference</Info>
        </vmw:TagBasedPlacementSection>

    </VirtualSystemCollection>

</Envelope>
