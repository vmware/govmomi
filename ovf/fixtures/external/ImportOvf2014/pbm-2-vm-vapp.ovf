<?xml version="1.0" encoding="UTF-8"?>

<!--
  Two VirtualSystem OVF containing tag based placement sections.
  This is for testing basic PBM OVF integration.
  -->

<Envelope vmw:buildId="build-258902" xmlns="http://schemas.dmtf.org/ovf/envelope/1" xmlns:cim="http://schemas.dmtf.org/wbem/wscim/1/common" xmlns:ovf="http://schemas.dmtf.org/ovf/envelope/1" xmlns:rasd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData" xmlns:vmw="http://www.vmware.com/schema/ovf" xmlns:vssd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_VirtualSystemSettingData" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <References>
        <File ovf:href="nostalgia-disk1.vmdk" ovf:id="file1" ovf:size="6872576" />
    </References>

    <DiskSection>
        <Info>Virtual disk information</Info>
        <Disk ovf:capacity="107373568" ovf:diskId="vmdisk1" ovf:fileRef="file1" ovf:format="http://www.vmware.com/interfaces/specifications/vmdk.html#streamOptimized" />
    </DiskSection>

    <NetworkSection>
        <Info>The list of logical networks</Info>
        <Network ovf:name="none">
            <Description>The none network</Description>
        </Network>
    </NetworkSection>

    <vmw:TagBasedPlacementGroupSection vmw:id="group1" vmw:name="TagGroup1">
        <Info>Tag based placement policy for group of VMs</Info>
        <vmw:Description>Tag based placement policy for group1 tier</vmw:Description>
        <vmw:TagCategory vmw:name="ovf-test-policy" vmw:id="##CAT_ID##"/>
        <vmw:TagValue vmw:name="ovf-test-policy-tag-0" vmw:id="##TAG_ID##"/>
    </vmw:TagBasedPlacementGroupSection>

	<VirtualSystemCollection ovf:id="pbm1TBP1VAPP2VMs">
		<Info>A multi-tiered software solution</Info>
		<Name>pbm1TBP1VAPP2VMs</Name>
		<VirtualSystem ovf:id="vs1">
			<Info>A virtual machine</Info>
			<Name>Test System</Name>

			<VirtualHardwareSection>
				<Info>Virtual hardware requirements</Info>
			</VirtualHardwareSection>

			<vmw:TagBasedPlacementSection vmw:group="group1" vmw:priority="0">
				<Info>Tag based placement policy group reference</Info>
			</vmw:TagBasedPlacementSection>
		</VirtualSystem>
		
		<VirtualSystem ovf:id="vs2">
			<Info>A virtual machine</Info>
			<Name>Test System</Name>

			<VirtualHardwareSection>
				<Info>Virtual hardware requirements</Info>
			</VirtualHardwareSection>

			<vmw:TagBasedPlacementSection vmw:group="group1" vmw:priority="0">
				<Info>Tag based placement policy group reference</Info>
			</vmw:TagBasedPlacementSection>
		</VirtualSystem>
	</VirtualSystemCollection>
</Envelope>
