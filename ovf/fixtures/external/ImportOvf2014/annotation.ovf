<?xml version="1.0" encoding="UTF-8"?>
<!--

AnnotationSection on a VirtualSystemCollection and on a VirtualSystem.

 -->
<Envelope
    xmlns="http://schemas.dmtf.org/ovf/envelope/1"
    xmlns:ovf="http://schemas.dmtf.org/ovf/envelope/1"
    xmlns:vmw="http://www.vmware.com/schema/ovf">

    <References/>

    <VirtualSystemCollection ovf:id="vsc1">
        <Info>A vApp</Info>
        <Name>Test vApp</Name>

        <AnnotationSection>
            <Info>An annotation on this service. It can be ignored</Info>
            <Annotation>Annotation on parent vApp</Annotation>
        </AnnotationSection>

        <VirtualSystem ovf:id="vs1">
            <Info>A virtual machine</Info>
            <Name>Test VM</Name>

            <AnnotationSection>
                <Info>An annotation on this service. It can be ignored</Info>
                <Annotation>Annotation on child VM</Annotation>
            </AnnotationSection>

            <VirtualHardwareSection>
                <Info>Virtual hardware requirements</Info>
            </VirtualHardwareSection>
        </VirtualSystem>

    </VirtualSystemCollection>

</Envelope>