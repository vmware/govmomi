<?xml version="1.0" encoding="UTF-8"?>
<Envelope xmlns="http://schemas.dmtf.org/ovf/envelope/1" xmlns:ovf="http://schemas.dmtf.org/ovf/envelope/1" xmlns:vmw="http://www.vmware.com/schema/ovf"
    xmlns:rasd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_ResourceAllocationSettingData" xmlns:vssd="http://schemas.dmtf.org/wbem/wscim/1/cim-schema/2/CIM_VirtualSystemSettingData"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <References />

    <!-- Unusual to have a storage group when there are no disks, but should be legal enough -->

    <vmw:StorageGroupSection vmw:id="group1" vmw:name="My Storage Profile" />

    <VirtualSystem ovf:id="vs1">
        <Info>A virtual machine</Info>
        <Name>Test System</Name>
        <vmw:StorageSection vmw:group="group1" />

        <VirtualHardwareSection>
            <Info>Virtual hardware requirements</Info>
        </VirtualHardwareSection>
    </VirtualSystem>
</Envelope>
