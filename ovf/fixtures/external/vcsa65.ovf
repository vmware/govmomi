  <DeploymentOptionSection>
    <Info>List of profiles</Info>
    <Configuration ovf:default="true" ovf:id="tiny">
      <Label>Tiny vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Tiny VM configured with 2 vCPUs and 8 GB of memory and requires 160 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 10 hosts and 100 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="small">
      <Label>Small vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Small VM configured with 4 vCPUs and 16 GB of memory and requires 300 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 100 hosts and 1,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="medium">
      <Label>Medium vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Medium VM configured with 8 vCPUs and 24 GB of memory and requires 450 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 400 hosts and 4,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="large">
      <Label>Large vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Large VM configured with 16 vCPUs and 32 GB of memory and requires 740 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 1000 hosts and 10,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="xlarge">
      <Label>X-Large vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a X-Large VM configured with 24 vCPUs and 48 GB of memory and requires 1080 GB of disk space will be updated for xlarge later. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 2000 hosts and 35,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="management-tiny">
      <Label>Tiny vCenter Server</Label>
      <Description>This will deploy a Tiny VM configured with 2 vCPUs and 8 GB of memory and requires 160 GB of disk space. These resources will be used by the vCenter Server services to manage up to 10 hosts and 100 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="management-small">
      <Label>Small vCenter Server</Label>
      <Description>This will deploy a Small VM configured with 4 vCPUs and 16 GB of memory and requires 300 GB of disk space. These resources will be used by the vCenter Server services to manage up to 100 hosts and 1,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="management-medium">
      <Label>Medium vCenter Server</Label>
      <Description>This will deploy a Medium VM configured with 8 vCPUs and 24 GB of memory and requires 450 GB of disk space. These resources will be used by the vCenter Server services to manage up to 400 hosts and 4,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="management-large">
      <Label>Large vCenter Server</Label>
      <Description>This will deploy a Large VM configured with 16 vCPUs and 32 GB of memory and requires 740 GB of disk space. These resources will be used by the vCenter Server services to manage up to 1000 hosts and 10,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="management-xlarge">
      <Label>X-Large vCenter Server</Label>
      <Description>This will deploy a X-Large VM configured with 24 vCPUs and 48 GB of memory and requires 1080 GB of disk space, xlarge disk space will be updated later. These resources will be used by the vCenter Server services to manage up to 2000 hosts and 35,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="tiny-lstorage">
      <Label>Tiny vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a Tiny VM configured with 2 vCPUs and 8 GB of memory and requires 700 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 10 hosts and 100 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="small-lstorage">
      <Label>Small vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a Small VM configured with 4 vCPUs and 16 GB of memory and requires 830 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 100 hosts and 1,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="medium-lstorage">
      <Label>Medium vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a Medium VM configured with 8 vCPUs and 24 GB of memory and requires 950 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 400 hosts and 4,000 VMs.</Description>
    </Configuration>
